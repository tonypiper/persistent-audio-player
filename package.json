{
  "name": "persistent-audio-player",
  "version": "1.0.4",
  "description": "Obsidian plugin for persistent audio playback",
  "main": "main.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json CHANGELOG.md",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.4.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.1"
  }
}
